{
  "compilerOptions": {
    "types": ["node"],
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "outDir": "dist",
    "rootDir": ".",
    "sourceMap": true,
    "declaration": true
  },
  "include": ["src", "test"]
}
