{
  "name": "aether",
  "description": "Aether trading bot",
  "version": "0.1.0",
  "main": "index.js",
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc && npm run copy-assets",
    "copy-assets": "mkdir -p dist/src/plugins/store/sqliteMigrations && cp src/plugins/store/sqliteMigrations/*.sql dist/src/plugins/store/sqliteMigrations/",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "biome:lint": "biome lint .",
    "biome:format": "biome format . --write",
    "biome:check": "biome check .",
    "biome:check:fix": "biome check . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "npm run typecheck && npm run biome:check:fix && npm run test:coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2"
  }
}
